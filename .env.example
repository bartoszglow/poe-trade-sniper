# Copy to .env and adjust. All keys are validated at boot (apps/server/src/config/env.ts).

# development | production | test
APP_ENV=development

# HTTP port for the sniper server
PORT=3500

# SQLite database file (relative to apps/server working directory)
DB_PATH=./data/dev.db

# --- GGG trade API (defaults shown; all optional) ---
# POE_BASE_URL=https://www.pathofexile.com
# League used when adding a search by bare id
DEFAULT_LEAGUE=Standard
# OUTBOUND_TIMEOUT_MS=15000

# --- detection tunables (see apps/server/src/config/env.ts for floors) ---
# POLL_INTERVAL_MS=12000
# FETCH_SPACING_MS=600
# FETCH_BATCH_SIZE=10
# MAX_FRESH_IDS_PER_TICK=20
# SEEN_IDS_CAP=5000

# --- live WebSocket ---
# WS_HANDSHAKE_TIMEOUT_MS=10000
# Routine post-stable reconnect uses the first rung; no dark ladder otherwise
# WS_RECONNECT_LADDER_MS=1000,5000,20000,60000
# Cadence of the single shared "is the live ws backend up?" background probe
# WS_UPGRADE_PROBE_INTERVAL_MS=120000
# WS_KEEPALIVE_PING_MS=30000
# A connection must survive this long to count as stable (routine vs unstable drop)
# WS_STABLE_CONNECTION_MS=60000

# --- outbound safety guard (runaway watchdog; trip = manual reset) ---
# GUARD_MAX_HTTP_PER_MINUTE=90
# GUARD_MAX_WS_CONNECTS_PER_MINUTE=12

# --- persistence hygiene ---
# HITS_MAX_ROWS=10000
