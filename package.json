{
  "name": "poe-trade-sniper",
  "version": "0.1.0",
  "private": true,
  "description": "PoE2 trade sniper — detection + browser-free travel, one server, two shells (web + Electron)",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @poe-sniper/server --filter @poe-sniper/web dev",
    "dev:desktop": "pnpm --filter @poe-sniper/shared --filter @poe-sniper/server build && pnpm --filter @poe-sniper/desktop abi:electron && pnpm --parallel --filter @poe-sniper/web --filter @poe-sniper/desktop dev:desktop:run",
    "abi:node": "pnpm --filter @poe-sniper/desktop abi:node",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "verify": "pnpm lint && pnpm typecheck && pnpm test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:e2e": "playwright test",
    "db:migrate": "pnpm --filter @poe-sniper/server db:migrate",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
